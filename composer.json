{
    "name": "ionysdev/pkuatia",
    "description": "Implementacion en PHP de la interfaz con el sistema EKuatia de faturacion electronica de Paraguay",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "IonysDev\\Pkuatia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IonysDev\\Pkuatia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Abilio Mancuello Petters",
            "email": "abiliomp@ionys.com.py"
        },
        {
            "name": "Gabriel Gauto",
            "email": "ggauto@ionys.com.py"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "ext-soap": "*",
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "ext-bcmath": "*",
        "robrichards/xmlseclibs": "^3.1.5",
        "krowinski/bcmath-extended": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.63"
    }
}
